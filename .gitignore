# ============================================
# Uber Backend Clone — .gitignore
# .NET 9 / ASP.NET Core / EF Core / Docker
# ============================================

# ── Build outputs ──────────────────────────
bin/
obj/
out/

# ── .NET ───────────────────────────────────
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/
.vscode/
*.DotSettings.user

# Rider / JetBrains
.idea/
*.sln.iml

# ── EF Core Migrations temp files ──────────
# Keep your Migrations folder — do NOT ignore it
# Only ignore the snapshot if you want (usually keep it)
# **/Migrations/

# ── App secrets & config ───────────────────
appsettings.Development.json
appsettings.Local.json
secrets.json
*.pfx
*.p12

# NEVER commit these
.env
.env.local
.env.development
.env.production

# ── User secrets (ASP.NET Core) ────────────
**/Properties/launchSettings.json

# ── Logs ───────────────────────────────────
logs/
*.log
Seq/

# ── Docker ─────────────────────────────────
# Keep your Dockerfiles and compose — ignore local override
docker-compose.override.yml

# ── Redis / Kafka local data ───────────────
redis-data/
kafka-data/
zookeeper-data/

# ── Postgres local data ─────────────────────
postgres-data/
pgdata/

# ── Test results ───────────────────────────
TestResults/
coverage/
*.coverage
*.coveragexml
*.trx

# ── NuGet ──────────────────────────────────
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
artifacts/
packages/

# ── macOS ──────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Windows ────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Stripe ─────────────────────────────────
# Never commit real keys — use env vars or user secrets
stripe-cli/

# ── Firebase ───────────────────────────────
google-services.json
firebase-adminsdk*.json
GoogleService-Info.plist

# ── JWT / Auth secrets ─────────────────────
# These should live in env vars or user secrets, never in git
jwt-keys/
*.pem
*.key

# ── Publish output ─────────────────────────
publish/
**/publish/

# ── Rider EF migration helpers ─────────────
efbundle
efbundle.exe